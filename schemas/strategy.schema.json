{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://autokairos.local/schemas/strategy.schema.json",
  "title": "AutoKairos Strategy Workspace",
  "type": "object",
  "additionalProperties": false,
  "required": ["artifact_id", "slug", "schema_version", "active", "indexes"],
  "properties": {
    "artifact_id": {
      "type": "string",
      "description": "Opaque machine identifier for the artifact lineage."
    },
    "slug": {
      "type": "string",
      "description": "Human-facing alias for the strategy asset."
    },
    "schema_version": {
      "type": "string"
    },
    "active": {
      "type": "object",
      "additionalProperties": false,
      "required": ["live_lane_ref", "current_checkpoint_ref", "export_policy_ref"],
      "properties": {
        "live_lane_ref": {
          "type": "string"
        },
        "current_checkpoint_ref": {
          "type": "string"
        },
        "export_policy_ref": {
          "type": "string"
        }
      }
    },
    "indexes": {
      "type": "object",
      "additionalProperties": true,
      "required": ["checkpoints_ref", "collections_ref", "imports_ref", "operations_ref", "sessions_ref"],
      "properties": {
        "checkpoints_ref": {
          "type": "string"
        },
        "collections_ref": {
          "type": "string"
        },
        "imports_ref": {
          "type": "string"
        },
        "operations_ref": {
          "type": "string"
        },
        "sessions_ref": {
          "type": "string"
        }
      }
    }
  }
}
