{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ouroboros.local/schemas/improvement-proposal-provider-output.schema.json",
  "title": "Artifact Change Proposal Provider Output",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "output_kind",
    "trading_evaluation_task_ref",
    "source_finding_refs",
    "proposal_summary",
    "requested_change_summary",
    "proposed_artifact_refs",
    "output_authority_status"
  ],
  "properties": {
    "output_kind": {
      "const": "improvement_proposal_input"
    },
    "trading_evaluation_task_ref": {
      "$ref": "#/$defs/ref"
    },
    "source_finding_refs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/ref"
      }
    },
    "anti_hacking_finding_refs": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/ref"
      }
    },
    "parent_system_code_ref": {
      "$ref": "#/$defs/ref"
    },
    "proposal_summary": {
      "type": "string",
      "minLength": 1
    },
    "requested_change_summary": {
      "type": "string",
      "minLength": 1
    },
    "expected_improvement_summary": {
      "type": "string",
      "minLength": 1
    },
    "proposed_artifact_refs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/ref"
      }
    },
    "output_authority_status": {
      "const": "proposal_input_only"
    }
  },
  "$defs": {
    "ref": {
      "type": "object",
      "additionalProperties": false,
      "required": ["record_kind", "id"],
      "properties": {
        "record_kind": {
          "type": "string",
          "minLength": 1
        },
        "id": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
