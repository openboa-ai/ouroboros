{
  "name": "ouroboros",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "trading:research": "tsx apps/runtime/src/trading-research/run-trading-research.ts",
    "trading:research:ledger": "node scripts/trading-research-ledger.mjs",
    "trading:research:best-artifact": "node scripts/trading-research-best-artifact.mjs",
    "trading:research:promote-candidate": "node scripts/trading-research-promote-candidate.mjs",
    "trading:candidate:ledger": "node scripts/trading-candidate-ledger.mjs",
    "trading:replay:run": "tsx apps/runtime/src/trading-candidate/run-replay.ts",
    "trading:replay:ledger": "node scripts/trading-replay-run-ledger.mjs",
    "audit:s10-trading-research": "node scripts/audit-s10-trading-research.mjs",
    "audit:trading-research:seeded-stability": "node scripts/audit-trading-research-seeded-stability.mjs",
    "prove:trading-research:codex-sdx": "node scripts/prove-trading-research-codex-sdx.mjs",
    "prove:trading-research:seeded-codex-sdx": "node scripts/prove-trading-research-seeded-codex-sdx.mjs",
    "research:proposal:codex": "tsx apps/runtime/src/research-orchestration/run-codex-improvement-proposal.ts",
    "research:proposal:codex:audit": "tsx apps/runtime/src/research-orchestration/run-codex-improvement-proposal-audit.ts",
    "audit:s9-codex-sbx": "node scripts/audit-s9-codex-sbx.mjs",
    "audit:s9-codex-sdx": "OUROBOROS_SDX_BIN=${OUROBOROS_SDX_BIN:-sdx} node scripts/audit-s9-codex-sbx.mjs",
    "audit:s9-codex-sdx-local": "OUROBOROS_SBX_HOME=${OUROBOROS_SBX_HOME:-/private/tmp/ouro-s5-sdx-home} OUROBOROS_SDX_BIN=${OUROBOROS_SDX_BIN:-./scripts/sdx-docker-sandboxes} node scripts/audit-s9-codex-sbx.mjs",
    "dev:runtime": "npm run dev -w @ouroboros/runtime",
    "dev:operator-web": "npm run dev -w @ouroboros/operator-web",
    "hooks:install": "bash scripts/install-git-hooks.sh",
    "check:naming": "node scripts/check-naming-surface.mjs",
    "test": "vitest run",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "validate:s5-sbx": "node scripts/validate-s5-sbx-runtime.mjs",
    "validate:s5-sbx:preflight": "node scripts/validate-s5-sbx-runtime.mjs --preflight-only",
    "validate:s5-sdx": "OUROBOROS_SDX_BIN=${OUROBOROS_SDX_BIN:-sdx} node scripts/validate-s5-sbx-runtime.mjs",
    "validate:s5-sdx:preflight": "OUROBOROS_SDX_BIN=${OUROBOROS_SDX_BIN:-sdx} node scripts/validate-s5-sbx-runtime.mjs --preflight-only",
    "audit:s5-sbx": "node scripts/audit-s5-sbx-readiness.mjs",
    "audit:s5-sbx:completion": "node scripts/audit-s5-sbx-completion.mjs",
    "audit:s5-sbx:promotion": "node scripts/audit-s5-sbx-promotion.mjs",
    "audit:s5-sdx": "OUROBOROS_SDX_BIN=${OUROBOROS_SDX_BIN:-sdx} node scripts/audit-s5-sbx-readiness.mjs",
    "audit:s5-sdx:completion": "OUROBOROS_SDX_BIN=${OUROBOROS_SDX_BIN:-sdx} node scripts/audit-s5-sbx-completion.mjs",
    "audit:s5-sdx:promotion": "OUROBOROS_SDX_BIN=${OUROBOROS_SDX_BIN:-sdx} node scripts/audit-s5-sbx-promotion.mjs",
    "report:s5-sbx-blocker": "node scripts/report-s5-sbx-blocker.mjs",
    "report:s5-sdx-blocker": "OUROBOROS_SDX_BIN=${OUROBOROS_SDX_BIN:-sdx} node scripts/report-s5-sbx-blocker.mjs",
    "login:s5-sbx-isolated": "HOME=${OUROBOROS_SBX_HOME:?Set OUROBOROS_SBX_HOME to the isolated Docker Sandboxes home} ${OUROBOROS_SBX_BIN:-sbx} login",
    "login:s5-sdx-isolated": "HOME=${OUROBOROS_SBX_HOME:?Set OUROBOROS_SBX_HOME to the isolated Docker Sandboxes home} ${OUROBOROS_SDX_BIN:-./scripts/sdx-docker-sandboxes} login",
    "resume:s5-sbx-isolated": "OUROBOROS_SBX_HOME=${OUROBOROS_SBX_HOME:?Set OUROBOROS_SBX_HOME to the isolated Docker Sandboxes home} OUROBOROS_ALLOW_SBX_DAEMON_RESTART=1 npm run recover:s5-sbx-daemon:validate",
    "resume:s5-sdx-isolated": "OUROBOROS_SBX_HOME=${OUROBOROS_SBX_HOME:?Set OUROBOROS_SBX_HOME to the isolated Docker Sandboxes home} OUROBOROS_SDX_BIN=${OUROBOROS_SDX_BIN:-./scripts/sdx-docker-sandboxes} OUROBOROS_ALLOW_SBX_DAEMON_RESTART=1 npm run recover:s5-sdx-daemon:validate",
    "login:s5-sdx-local": "OUROBOROS_SBX_HOME=${OUROBOROS_SBX_HOME:-/private/tmp/ouro-s5-sdx-home} OUROBOROS_SDX_BIN=${OUROBOROS_SDX_BIN:-./scripts/sdx-docker-sandboxes} npm run login:s5-sdx-isolated",
    "resume:s5-sdx-local": "OUROBOROS_SBX_HOME=${OUROBOROS_SBX_HOME:-/private/tmp/ouro-s5-sdx-home} OUROBOROS_SDX_BIN=${OUROBOROS_SDX_BIN:-./scripts/sdx-docker-sandboxes} npm run resume:s5-sdx-isolated",
    "validate:s5-sdx-local:preflight": "OUROBOROS_SBX_HOME=${OUROBOROS_SBX_HOME:-/private/tmp/ouro-s5-sdx-home} OUROBOROS_SDX_BIN=${OUROBOROS_SDX_BIN:-./scripts/sdx-docker-sandboxes} npm run validate:s5-sdx:preflight",
    "validate:s5-sdx-local": "OUROBOROS_SBX_HOME=${OUROBOROS_SBX_HOME:-/private/tmp/ouro-s5-sdx-home} OUROBOROS_SDX_BIN=${OUROBOROS_SDX_BIN:-./scripts/sdx-docker-sandboxes} npm run validate:s5-sdx",
    "report:s5-sdx-local-blocker": "OUROBOROS_SBX_HOME=${OUROBOROS_SBX_HOME:-/private/tmp/ouro-s5-sdx-home} OUROBOROS_SDX_BIN=${OUROBOROS_SDX_BIN:-./scripts/sdx-docker-sandboxes} npm run report:s5-sdx-blocker -- --write-default-report",
    "audit:s5-sdx-local:promotion": "OUROBOROS_SBX_HOME=${OUROBOROS_SBX_HOME:-/private/tmp/ouro-s5-sdx-home} OUROBOROS_SDX_BIN=${OUROBOROS_SDX_BIN:-./scripts/sdx-docker-sandboxes} npm run audit:s5-sdx:promotion --",
    "recover:s5-sbx-daemon": "node scripts/recover-s5-sbx-daemon.mjs",
    "recover:s5-sbx-daemon:validate": "node scripts/recover-s5-sbx-daemon.mjs --apply --validate-after-apply",
    "recover:s5-sdx-daemon": "OUROBOROS_SDX_BIN=${OUROBOROS_SDX_BIN:-sdx} node scripts/recover-s5-sbx-daemon.mjs",
    "recover:s5-sdx-daemon:validate": "OUROBOROS_SDX_BIN=${OUROBOROS_SDX_BIN:-sdx} node scripts/recover-s5-sbx-daemon.mjs --apply --validate-after-apply"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "typescript": "^5.9.3",
    "vite": "^7.2.4",
    "vitest": "^4.0.14"
  },
  "dependencies": {
    "@fastify/cors": "^11.1.0",
    "@fastify/rate-limit": "^10.3.0",
    "fastify": "^5.6.2",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "tsx": "^4.21.0"
  }
}
