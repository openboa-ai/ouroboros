{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/openboa-ai/ouroboros/docs/schemas/trading-system-paper-event.schema.json",
  "title": "TradingSystem Paper Event",
  "type": "object",
  "required": ["event", "event_id", "instance_id", "at", "authority_status"],
  "properties": {
    "event": {
      "enum": ["order_request", "cancel_order", "hold", "no_action"]
    },
    "event_id": {
      "type": "string",
      "minLength": 1
    },
    "instance_id": {
      "type": "string",
      "minLength": 1
    },
    "at": {
      "type": "string",
      "minLength": 1
    },
    "authority_status": {
      "const": "trace_only"
    },
    "intent_kind": {
      "const": "place_order"
    },
    "symbol": {
      "const": "BTCUSDT"
    },
    "side": {
      "enum": ["buy", "sell"]
    },
    "order_type": {
      "enum": ["market", "limit"]
    },
    "quantity": {
      "type": "string",
      "pattern": "^-?[0-9]+(\\.[0-9]+)?$"
    },
    "limit_price": {
      "type": "string",
      "pattern": "^[0-9]+(\\.[0-9]+)?$"
    },
    "order_id": {
      "type": "string",
      "minLength": 1
    },
    "reason": {
      "type": "string",
      "minLength": 1
    },
    "runtime_environment": {
      "not": {
        "const": "live"
      }
    },
    "signed_request": {
      "const": false
    },
    "listenKey": false,
    "user_data_stream": false,
    "leverage": false,
    "margin": false,
    "api_key": false,
    "signature": false
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "event": {
            "const": "order_request"
          }
        },
        "required": ["event"]
      },
      "then": {
        "required": ["intent_kind", "symbol", "side", "order_type", "quantity"]
      }
    },
    {
      "if": {
        "properties": {
          "event": {
            "const": "order_request"
          },
          "order_type": {
            "const": "limit"
          }
        },
        "required": ["event", "order_type"]
      },
      "then": {
        "required": ["limit_price"]
      }
    },
    {
      "if": {
        "properties": {
          "event": {
            "enum": ["cancel_order", "hold", "no_action"]
          }
        },
        "required": ["event"]
      },
      "then": {
        "required": ["reason"]
      }
    }
  ]
}
